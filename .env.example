NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Web Push (VAPID). Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# The following are set as Supabase Edge Function secrets, not Next.js env:
#   supabase secrets set VAPID_PUBLIC_KEY=... VAPID_PRIVATE_KEY=... \
#     VAPID_SUBJECT=mailto:you@example.com PUSH_FUNCTION_SECRET=... \
#     APP_ORIGIN=https://your-app.example
# And as database settings (one-time per environment):
#   alter database postgres set app.supabase_url = 'https://<ref>.supabase.co';
#   alter database postgres set app.push_function_secret = '<same secret>';

